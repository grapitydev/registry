{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabled": true,
  "semanticCommitType": "deps",
  "packageRules": [
    {
      "matchPackagePatterns": ["@grapity/*"],
      "rangeStrategy": "bump",
      "semanticCommitType": "deps",
      "separateMajorMinor": true
    },
    {
      "matchPackagePatterns": ["@grapity/*"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchPackagePatterns": ["!@grapity/*"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "platformAutomerge": true
    }
  ]
}
