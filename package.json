{
  "name": "@grapity/registry",
  "version": "0.0.2",
  "description": "Grapity Registry - spec validation, compat checking, and storage server",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/grapitydev/registry"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    },
    "./serve": {
      "bun": "./src/serve.ts",
      "import": {
        "types": "./dist/serve.d.ts",
        "default": "./dist/serve.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "bun run src/serve.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "generate": "openapi-typescript openapi.yaml -o src/generated/api.ts",
    "db:generate:sqlite": "drizzle-kit generate --config drizzle.config.sqlite.ts",
    "db:generate:pg": "drizzle-kit generate --config drizzle.config.pg.ts",
    "db:migrate:sqlite": "drizzle-kit migrate --config drizzle.config.sqlite.ts",
    "db:migrate:pg": "drizzle-kit migrate --config drizzle.config.pg.ts",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@grapity/core": "^0.0.3",
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "drizzle-orm": "^0.44.0",
    "better-sqlite3": "^11.9.0",
    "pg": "^8.16.0",
    "@apidevtools/swagger-parser": "^10.1.0",
    "uuid": "^11.1.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}